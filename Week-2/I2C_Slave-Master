#include <Wire.h>

String receivedData = "";

void setup() {
  Wire.begin(8);      // Slave Address = 8
  Wire.onReceive(receiveEvent);
  Wire.onRequest(requestEvent);

  Serial.begin(9600);
}

void loop() {
  delay(100);
}

// Function executed when data is received
void receiveEvent(int bytes) {

  receivedData = "";

  while (Wire.available()) {
    char c = Wire.read();
    receivedData += c;
  }

  Serial.print("Received: ");
  Serial.println(receivedData);
}

// Function executed when Master requests data
void requestEvent() {
  Wire.write("Hello Master");
}
