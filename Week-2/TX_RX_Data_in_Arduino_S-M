#include <SoftwareSerial.h>
SoftwareSerial mySerial(2, 3); // RX = pin 2, TX = pin 3
void setup() {
Serial.begin(9600); // USB Serial Monitor (for debugging on PC)
mySerial.begin(9600); // Software Serial link to Master Arduino
Serial.println("Slave Ready");
}
void loop() {
if (mySerial.available()) { // RX: check for message
String msg = mySerial.readStringUntil('\n');
Serial.print("Slave Received: ");
  Serial.println(msg);
mySerial.println("Yes Master, I am here!"); // TX: send reply
Serial.println("Slave Sent: Yes Master, I am here!");
}
}
