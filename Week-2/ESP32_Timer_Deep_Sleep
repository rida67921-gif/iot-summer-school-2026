#define BUTTON_PIN 4
#define TIME_TO_SLEEP  10        
#define uS_TO_S_FACTOR 10000000ULL  

void setup() {
  Serial.begin(115200);
  delay(1000); 

  Serial.println("ESP32 Woke Up!");
  Serial.println("Doing work... reading sensors...");
  delay(2000); 

  esp_sleep_enable_timer_wakeup(TIME_TO_SLEEP * uS_TO_S_FACTOR);
  
  Serial.println("Going to sleep now for 10 seconds...");
  Serial.flush(); 
  
  esp_deep_sleep_start();
}

void loop() {
}
