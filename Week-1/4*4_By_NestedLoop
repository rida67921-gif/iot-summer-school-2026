#include <iostream>
using namespace std;

int main() {
    // Outer loop for rows (1 to 4)
    for (int i = 1; i <= 4; i++) {
        // Inner loop for columns (1 to 3)
        for (int j = 1; j <= 3; j++) {
            cout << "Sensor(" << i << "," << j << ") ";
        }
    }
    
    return 0;
}
